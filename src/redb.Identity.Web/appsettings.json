{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "//": [
      "Identity OIDC host endpoint. Default points at the Tsak.Worker-hosted redb.Identity.Http",
      "module (context 'identity.http' / IdentityTransport:Http:PublicPort, see redb.Identity/context.json).",
      "Must match the Issuer claim emitted by the host (id_token 'iss')."
    ],
    "Authority": "http://localhost:5002",
    "MetadataAddress": "http://localhost:5002/.well-known/openid-configuration",
    "RequireHttpsMetadata": false,
    "ApiBaseUrl": "http://localhost:5002",
    "ClientId": "identity-web",
    "ClientSecret": "<DEV_SECRET_PLACEHOLDER>",
    "Scopes": [ "openid", "profile", "email", "roles", "offline_access", "identity:manage", "identity:account" ],

    "//BackchannelClient": [
      "W6-0 service account for revoked-sids backchannel polling.",
      "ClientId is shipped here (not a secret); ClientSecret MUST come from env-var:",
      "  Identity__BackchannelClient__ClientSecret=<value>",
      "and the SAME value must be set on the Identity host as:",
      "  Tsak__Contexts__identity.core__Override__Identity__SeedBackchannelClient__ClientSecret=<value>",
      "Helper: redb.Identity/scripts/dev-backchannel-secret.ps1 generates one secret and sets both env-vars."
    ],
    "BackchannelClient": {
      "ClientId": "identity-backchannel",
      "ClientSecret": "<DEV_SECRET_PLACEHOLDER>",
      "Scopes": [ "identity:manage" ]
    }
  },
  "Bootstrap": {
    "Enabled": false,
    "Endpoint": "http://localhost:5002/internal/bootstrap-admin",
    "Secret": "<DEV_SECRET_PLACEHOLDER>"
  }
}

