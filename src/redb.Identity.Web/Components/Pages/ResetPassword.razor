@page "/reset-password"
@attribute [AllowAnonymous]

<PageTitle>Reset password — redb.Identity</PageTitle>

<div class="login-backdrop">
    <div class="login-card">
        <div class="login-brand">
            <RdbIcon Name="shield" Size="28" />
            <span class="login-brand-name">redb.Identity</span>
        </div>

        <h2 class="login-title">Choose a new password</h2>

        @if (string.IsNullOrEmpty(Token) || string.IsNullOrEmpty(Jti))
        {
            <div class="login-error" role="alert" aria-live="polite">
                <RdbIcon Name="alert-circle" Size="16" />
                <span>This reset link is incomplete. Please request a new one.</span>
            </div>
            <div class="login-actions">
                <a href="/forgot-password" class="btn btn-primary">Request new link</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="login-error" role="alert" aria-live="polite">
                    <RdbIcon Name="alert-circle" Size="16" />
                    <span>@ErrorMessage</span>
                </div>
            }

            <form method="post" action="/api/auth/password/reset" class="login-form">
                <AntiforgeryToken />
                <input type="hidden" name="token" value="@Token" />
                <input type="hidden" name="jti" value="@Jti" />

                <div class="float-field">
                    <input id="newPassword" name="newPassword" type="password" placeholder=" "
                           autocomplete="new-password" minlength="8" required />
                    <label for="newPassword">New password</label>
                </div>

                <div class="float-field">
                    <input id="confirmPassword" name="confirmPassword" type="password" placeholder=" "
                           autocomplete="new-password" minlength="8" required />
                    <label for="confirmPassword">Confirm new password</label>
                </div>

                <div class="login-actions">
                    <button type="submit" class="btn btn-primary login-btn">
                        <RdbIcon Name="key" Size="16" />
                        <span>Update password</span>
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@code {
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Jti { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string ErrorMessage => Error switch
    {
        "invalid_token" => "This reset link is invalid or has expired. Please request a new one.",
        "weak_password" => "The new password does not meet the complexity requirements.",
        "password_mismatch" => "The two password fields do not match.",
        "missing_fields" => "Please fill in both password fields.",
        _ => "We couldn't reset your password. Please request a new link."
    };
}
