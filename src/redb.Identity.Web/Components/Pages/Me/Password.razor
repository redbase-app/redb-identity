@page "/me/password"
@attribute [Authorize]
@inject IIdentityClient Client
@inject ToastService Toast

<RdbPageHeader Title="Change password" Description="Set a new password. All your sessions will be revoked." />

<div class="card" style="max-width: 480px;">
    <div class="card-header">
        <span class="card-title">Password</span>
    </div>

    <label class="form-field">Current password <input type="password" @bind="_form.OldPassword" /></label>
    <label class="form-field">New password <input type="password" @bind="_form.NewPassword" /></label>
    <label class="form-field">Confirm new password <input type="password" @bind="_confirm" /></label>

    @if (_error is not null) { <p class="text-error">@_error</p> }

    <div style="display:flex; gap: var(--space-2); justify-content: flex-end; margin-top: var(--space-4);">
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
            @(_saving ? "Saving…" : "Change password")
        </button>
    </div>
</div>

@code {
    private MeChangePasswordRequest _form = new() { OldPassword = "", NewPassword = "" };
    private string _confirm = "";
    private bool _saving;
    private string? _error;

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrEmpty(_form.NewPassword) || _form.NewPassword != _confirm)
        {
            _error = "New password and confirmation do not match.";
            return;
        }

        _saving = true;
        try
        {
            await Client.ChangeMyPasswordAsync(_form);
            Toast.Success("Password changed. You may be signed out shortly.");
            _form = new() { OldPassword = "", NewPassword = "" };
            _confirm = "";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
