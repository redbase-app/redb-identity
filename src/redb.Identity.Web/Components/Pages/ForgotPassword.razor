@page "/forgot-password"
@attribute [AllowAnonymous]

<PageTitle>Reset password — redb.Identity</PageTitle>

<div class="login-backdrop">
    <div class="login-card">
        <div class="login-brand">
            <RdbIcon Name="shield" Size="28" />
            <span class="login-brand-name">redb.Identity</span>
        </div>

        <h2 class="login-title">Forgot password</h2>
        <p class="login-subtitle">
            Enter the e-mail address associated with your account and we'll send you a
            link to reset your password.
        </p>

        @if (Sent is not null)
        {
            <div class="login-error" role="alert" aria-live="polite" style="background:#0f2a18;border-color:#1a5b32;">
                <RdbIcon Name="alert-circle" Size="16" />
                <span>
                    If an account exists for that e-mail, a reset link has been sent.
                    Please check your inbox (and spam folder).
                </span>
            </div>
        }
        else if (!string.IsNullOrEmpty(Error))
        {
            <div class="login-error" role="alert" aria-live="polite">
                <RdbIcon Name="alert-circle" Size="16" />
                <span>@ErrorMessage</span>
            </div>
        }

        <form method="post" action="/api/auth/password/forgot" class="login-form">
            <AntiforgeryToken />

            <div class="float-field">
                <input id="email" name="email" type="email" placeholder=" "
                       autocomplete="email" autofocus required />
                <label for="email">E-mail</label>
            </div>

            <div class="login-actions">
                <button type="submit" class="btn btn-primary login-btn">
                    <RdbIcon Name="mail" Size="16" />
                    <span>Send reset link</span>
                </button>
            </div>
        </form>

        <div class="login-divider">or</div>
        <div class="login-actions">
            <a href="/login" class="btn">Back to sign-in</a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [SupplyParameterFromQuery] public string? Sent { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string ErrorMessage => Error switch
    {
        "missing_email" => "Please enter your e-mail address.",
        _ => "We couldn't process that request. Please try again."
    };
}
